{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://callcatch.site/schemas/brain-two-output.json",
  "title": "CallCatch Brain Two - Outreach Intelligence v1.0",
  "type": "object",
  "required": [
    "version",
    "status",
    "eligibility",
    "ideal_contact_persona",
    "ranked_contact_personas",
    "selected_outreach_angle",
    "selected_offer",
    "offer_fit_explanation",
    "subject_lines",
    "first_email",
    "follow_up_emails",
    "concise_cta",
    "quality_check",
    "email_quality_gate",
    "why_this_email",
    "quality_feedback",
    "email_health",
    "follow_up_quality_gates",
    "outreach_confidence",
    "supporting_evidence",
    "prohibited_claims",
    "brain_three_handoff",
    "approval_state",
    "generation_mode"
  ],
  "properties": {
    "version": { "const": "brain-two-v1.0" },
    "status": { "enum": ["READY", "NEEDS_REVIEW", "BLOCKED"] },
    "eligibility": {
      "type": "object",
      "required": ["eligible", "status", "reasons", "brain_one_run_id", "manual_research_required"],
      "properties": {
        "eligible": { "type": "boolean" },
        "status": { "enum": ["eligible", "needs_review", "blocked"] },
        "reasons": { "type": "array", "items": { "type": "string" } },
        "brain_one_run_id": { "type": "string" },
        "manual_research_required": { "type": "boolean" }
      }
    },
    "ideal_contact_persona": {
      "type": "object",
      "required": ["persona", "reasoning", "confidence", "evidence_ids"],
      "properties": {
        "persona": { "type": "string" },
        "reasoning": { "type": "string" },
        "confidence": { "enum": ["high", "medium", "low"] },
        "evidence_ids": { "type": "array", "items": { "type": "string" } }
      }
    },
    "ranked_contact_personas": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["persona", "rank", "reasoning", "confidence", "evidence_ids"],
        "properties": {
          "persona": { "type": "string" },
          "rank": { "type": "integer" },
          "reasoning": { "type": "string" },
          "confidence": { "enum": ["high", "medium", "low"] },
          "evidence_ids": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "selected_outreach_angle": {
      "type": "object",
      "required": ["angle", "reasoning", "claim_type", "evidence_ids"],
      "properties": {
        "angle": { "type": "string" },
        "reasoning": { "type": "string" },
        "claim_type": { "enum": ["evidence_backed", "soft_hypothesis"] },
        "evidence_ids": { "type": "array", "items": { "type": "string" } }
      }
    },
    "selected_offer": {
      "type": "object",
      "required": ["name", "description", "reasoning", "evidence_ids"],
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "reasoning": { "type": "string" },
        "evidence_ids": { "type": "array", "items": { "type": "string" } }
      }
    },
    "offer_fit_explanation": { "type": "string" },
    "subject_lines": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": { "type": "string" }
    },
    "first_email": {
      "type": "object",
      "required": ["subject", "body", "evidence_ids", "claims"],
      "properties": {
        "subject": { "type": "string" },
        "body": { "type": "string" },
        "evidence_ids": { "type": "array", "items": { "type": "string" } },
        "claims": { "type": "array", "items": { "type": "string" } }
      }
    },
    "follow_up_emails": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": ["step", "stage", "stage_name", "founder_style", "recommended_delay_days", "subject", "subject_options", "body", "new_idea", "cta", "evidence_ids", "claims"],
        "properties": {
          "step": { "type": "integer" },
          "stage": { "type": "integer" },
          "stage_name": { "type": "string" },
          "founder_style": { "type": "string" },
          "recommended_delay_days": { "type": "integer" },
          "subject": { "type": "string" },
          "subject_options": {
            "type": "array",
            "minItems": 5,
            "maxItems": 5,
            "items": { "type": "string" }
          },
          "body": { "type": "string" },
          "new_idea": { "type": "string" },
          "cta": { "type": "string" },
          "evidence_ids": { "type": "array", "items": { "type": "string" } },
          "claims": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "concise_cta": { "type": "string" },
    "quality_check": {
      "type": "object",
      "required": ["quality_score", "confidence_score", "human_score", "passed", "spam_risk", "reading_level"],
      "properties": {
        "quality_score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "confidence_score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "human_score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "passed": { "type": "boolean" },
        "spam_risk": { "enum": ["Low", "Medium", "High"] },
        "reading_level": { "type": "number" }
      }
    },
    "email_quality_gate": {
      "type": "object",
      "required": ["status", "quality_score", "confidence_score", "human_score", "email_health", "checklist", "quality_feedback", "self_review", "passed", "regeneration_attempted", "final_action"],
      "properties": {
        "status": { "enum": ["READY TO REVIEW", "MARK FOR MANUAL REVIEW"] },
        "quality_score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "confidence_score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "human_score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "email_health": { "type": "object" },
        "checklist": { "type": "object" },
        "quality_feedback": { "type": "object" },
        "self_review": { "type": "object" },
        "passed": { "type": "boolean" },
        "regeneration_attempted": { "type": "boolean" },
        "final_action": { "enum": ["READY TO REVIEW", "MARK FOR MANUAL REVIEW"] }
      }
    },
    "why_this_email": {
      "type": "object",
      "required": ["evidence", "evidence_ids", "reason", "confidence"],
      "properties": {
        "evidence": { "type": "array", "items": { "type": "string" } },
        "evidence_ids": { "type": "array", "items": { "type": "string" } },
        "reason": { "type": "string" },
        "confidence": { "type": "string" }
      }
    },
    "quality_feedback": {
      "type": "object",
      "required": ["strengths", "weaknesses"],
      "properties": {
        "strengths": { "type": "array", "items": { "type": "string" } },
        "weaknesses": { "type": "array", "items": { "type": "string" } }
      }
    },
    "email_health": {
      "type": "object",
      "required": ["quality", "human", "confidence", "length", "reading_level", "spam_risk"],
      "properties": {
        "quality": { "type": "integer", "minimum": 0, "maximum": 100 },
        "human": { "type": "integer", "minimum": 0, "maximum": 100 },
        "confidence": { "type": "integer", "minimum": 0, "maximum": 100 },
        "length": { "type": "integer", "minimum": 0 },
        "reading_level": { "type": "number" },
        "spam_risk": { "enum": ["Low", "Medium", "High"] }
      }
    },
    "follow_up_quality_gates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["step", "stage_name", "status", "quality_score", "human_score", "confidence_score", "spam_risk"],
        "properties": {
          "step": { "type": "integer" },
          "stage_name": { "type": "string" },
          "status": { "enum": ["READY TO REVIEW", "MARK FOR MANUAL REVIEW"] },
          "quality_score": { "type": "integer", "minimum": 0, "maximum": 100 },
          "human_score": { "type": "integer", "minimum": 0, "maximum": 100 },
          "confidence_score": { "type": "integer", "minimum": 0, "maximum": 100 },
          "spam_risk": { "enum": ["Low", "Medium", "High"] }
        }
      }
    },
    "outreach_confidence": {
      "type": "object",
      "required": ["score", "level", "reasoning"],
      "properties": {
        "score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "level": { "enum": ["high", "medium", "low"] },
        "reasoning": { "type": "string" }
      }
    },
    "supporting_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim", "evidence_ids", "claim_type"],
        "properties": {
          "claim": { "type": "string" },
          "evidence_ids": { "type": "array", "items": { "type": "string" } },
          "claim_type": { "enum": ["evidence_backed", "soft_hypothesis"] }
        }
      }
    },
    "prohibited_claims": { "type": "array", "items": { "type": "string" } },
    "brain_three_handoff": {
      "type": "object",
      "required": ["lead_id", "brain_one_run_id", "brain_two_run_id", "selected_angle", "selected_offer", "reply_watch_items", "do_not_claim", "approval_required"],
      "properties": {
        "lead_id": { "type": "string" },
        "brain_one_run_id": { "type": "string" },
        "brain_two_run_id": { "type": "string" },
        "selected_angle": { "type": "string" },
        "selected_offer": { "type": "string" },
        "reply_watch_items": { "type": "array", "items": { "type": "string" } },
        "do_not_claim": { "type": "array", "items": { "type": "string" } },
        "approval_required": { "const": true }
      }
    },
    "approval_state": { "enum": ["pending-review", "approved", "rejected"] },
    "generation_mode": { "enum": ["deterministic", "model_assisted"] }
  }
}
