{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://callcatch.site/schemas/brain-one-output.json",
  "title": "CallCatch Brain One Phase A Analyst Intelligence Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "business_identity",
    "contacts",
    "business_dna",
    "evidence_log",
    "confirmed_facts",
    "inferences",
    "unknowns",
    "digital_health",
    "ai_discoverability",
    "future_readiness",
    "hidden_opportunities",
    "money_left_on_table",
    "ai_opportunity_radar",
    "why_we_chose_you",
    "one_day_action_plan",
    "risks",
    "contact_decision",
    "brain_two_handoff"
  ],
  "properties": {
    "business_identity": { "type": "object" },
    "contacts": { "type": "array" },
    "business_dna": { "type": "object" },
    "evidence_log": { "type": "array", "minItems": 1 },
    "confirmed_facts": { "type": "array" },
    "inferences": { "type": "array" },
    "unknowns": { "type": "array" },
    "digital_health": { "type": "object" },
    "ai_discoverability": { "type": "object" },
    "future_readiness": { "type": "object" },
    "hidden_opportunities": { "type": "array", "maxItems": 5 },
    "money_left_on_table": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": true,
          "required": ["status", "low_estimate", "high_estimate", "currency", "time_period", "calculation_method", "assumptions", "evidence_ids", "confidence", "disclaimer"],
          "properties": {
            "status": { "const": "estimated" },
            "low_estimate": { "type": "number" },
            "high_estimate": { "type": "number" },
            "currency": { "type": "string" },
            "time_period": { "type": "string" },
            "calculation_method": { "type": "string" },
            "assumptions": { "type": "array", "minItems": 1 },
            "evidence_ids": { "type": "array", "minItems": 1 },
            "confidence": { "enum": ["high", "medium", "low"] },
            "disclaimer": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": true,
          "required": ["status", "low_estimate", "high_estimate", "currency", "time_period", "calculation_method", "assumptions", "evidence_ids", "confidence", "disclaimer"],
          "properties": {
            "status": { "const": "insufficient_evidence" },
            "low_estimate": { "type": "null" },
            "high_estimate": { "type": "null" },
            "currency": { "type": "null" },
            "time_period": { "type": "null" },
            "calculation_method": { "type": "null" },
            "assumptions": { "type": "array", "maxItems": 0 },
            "evidence_ids": { "type": "array", "maxItems": 0 },
            "confidence": { "const": "low" },
            "disclaimer": { "const": "Insufficient evidence for a responsible monetary estimate." }
          }
        }
      ]
    },
    "ai_opportunity_radar": { "type": "object" },
    "why_we_chose_you": { "type": "object" },
    "one_day_action_plan": { "type": "object" },
    "risks": { "type": "array" },
    "contact_decision": { "type": "object" },
    "brain_two_handoff": { "type": "object" }
  }
}
