{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://callcatch.site/schemas/brain-one-output.json",
  "title": "CallCatch Brain One Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "businessIdentity",
    "businessDNA",
    "evidenceLog",
    "confirmedFacts",
    "inferences",
    "unknowns",
    "digitalHealthAssessment",
    "aiDiscoverabilityAssessment",
    "hiddenOpportunities",
    "revenueOpportunityEstimates",
    "risks",
    "recommendedPriority",
    "ownerContactConfidence",
    "businessGrowthBlueprint",
    "brainTwoHandoffContext"
  ],
  "properties": {
    "businessIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["businessName", "websiteUrl", "trade", "location"],
      "properties": {
        "businessName": { "type": "string" },
        "websiteUrl": { "type": "string" },
        "trade": { "type": "string" },
        "location": { "type": "string" }
      }
    },
    "businessDNA": {
      "type": "object",
      "additionalProperties": false,
      "required": ["positioning", "likelyCustomerBase", "serviceModel", "evidenceIds"],
      "properties": {
        "positioning": { "type": "string" },
        "likelyCustomerBase": { "type": "string" },
        "serviceModel": { "type": "string" },
        "evidenceIds": { "$ref": "#/$defs/evidenceIds" }
      }
    },
    "evidenceLog": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/evidenceItem" }
    },
    "confirmedFacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/claim" }
    },
    "inferences": {
      "type": "array",
      "items": { "$ref": "#/$defs/inference" }
    },
    "unknowns": {
      "type": "array",
      "items": { "type": "string" }
    },
    "digitalHealthAssessment": { "$ref": "#/$defs/scoredAssessment" },
    "aiDiscoverabilityAssessment": { "$ref": "#/$defs/scoredAssessment" },
    "hiddenOpportunities": {
      "type": "array",
      "items": { "$ref": "#/$defs/opportunity" }
    },
    "revenueOpportunityEstimates": {
      "type": "array",
      "items": { "$ref": "#/$defs/revenueEstimate" }
    },
    "risks": {
      "type": "array",
      "items": { "$ref": "#/$defs/risk" }
    },
    "recommendedPriority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "score", "reason", "evidenceIds"],
      "properties": {
        "level": { "type": "string", "enum": ["low", "medium", "high", "urgent"] },
        "score": { "type": "number", "minimum": 0, "maximum": 100 },
        "reason": { "type": "string" },
        "evidenceIds": { "$ref": "#/$defs/evidenceIds" }
      }
    },
    "ownerContactConfidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ownerName", "confidence", "contactPaths", "evidenceIds"],
      "properties": {
        "ownerName": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 100 },
        "contactPaths": { "type": "array", "items": { "type": "string" } },
        "evidenceIds": { "$ref": "#/$defs/evidenceIds" }
      }
    },
    "businessGrowthBlueprint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "nextBestActions", "callCatchFitRationale", "evidenceIds"],
      "properties": {
        "summary": { "type": "string" },
        "nextBestActions": { "type": "array", "items": { "type": "string" } },
        "callCatchFitRationale": { "type": "string" },
        "evidenceIds": { "$ref": "#/$defs/evidenceIds" }
      }
    },
    "brainTwoHandoffContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["approvedForHandoff", "summary", "evidenceIds", "doNotAutomateOutbound"],
      "properties": {
        "approvedForHandoff": { "type": "boolean" },
        "summary": { "type": "string" },
        "evidenceIds": { "$ref": "#/$defs/evidenceIds" },
        "doNotAutomateOutbound": { "type": "boolean" }
      }
    }
  },
  "$defs": {
    "evidenceIds": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "evidenceItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "sourceType", "sourceUrl", "excerpt"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "sourceType": { "type": "string" },
        "sourceUrl": { "type": "string" },
        "excerpt": { "type": "string" }
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim", "evidenceIds"],
      "properties": {
        "claim": { "type": "string" },
        "evidenceIds": { "$ref": "#/$defs/evidenceIds" }
      }
    },
    "inference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["inference", "reasoning", "confidence", "evidenceIds"],
      "properties": {
        "inference": { "type": "string" },
        "reasoning": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 100 },
        "evidenceIds": { "$ref": "#/$defs/evidenceIds" }
      }
    },
    "scoredAssessment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["score", "summary", "strengths", "gaps", "evidenceIds"],
      "properties": {
        "score": { "type": "number", "minimum": 0, "maximum": 100 },
        "summary": { "type": "string" },
        "strengths": { "type": "array", "items": { "type": "string" } },
        "gaps": { "type": "array", "items": { "type": "string" } },
        "evidenceIds": { "$ref": "#/$defs/evidenceIds" }
      }
    },
    "opportunity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["opportunity", "whyItMatters", "evidenceIds"],
      "properties": {
        "opportunity": { "type": "string" },
        "whyItMatters": { "type": "string" },
        "evidenceIds": { "$ref": "#/$defs/evidenceIds" }
      }
    },
    "revenueEstimate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "low", "high", "currency", "assumptions", "confidence", "evidenceIds"],
      "properties": {
        "label": { "type": "string" },
        "low": { "type": "number" },
        "high": { "type": "number" },
        "currency": { "type": "string" },
        "assumptions": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "confidence": { "type": "number", "minimum": 0, "maximum": 100 },
        "evidenceIds": { "$ref": "#/$defs/evidenceIds" }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["risk", "severity", "evidenceIds"],
      "properties": {
        "risk": { "type": "string" },
        "severity": { "type": "string", "enum": ["low", "medium", "high"] },
        "evidenceIds": { "$ref": "#/$defs/evidenceIds" }
      }
    }
  }
}
