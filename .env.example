# Server
PORT=8787
# Leave HOST blank locally. Render will bind automatically through the app code.
HOST=

# Production storage
# Optional but recommended on Render. Create a Render Postgres database and paste its Internal Database URL here.
DATABASE_URL=

# Email sending
# Recommended on Render: use Resend API over HTTPS.
EMAIL_PROVIDER=auto
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
BREVO_API_KEY=

# SMTP fallback only. Leave blank if using Resend or Brevo.
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME=CallCatch
SMTP_REPLY_TO=
SMTP_TIMEOUT_MS=15000

# Optional provider/integration placeholders
# Optional lead enrichment providers. Serper is recommended for finding official websites before email scanning.
SERPER_API_KEY=
BRAVE_SEARCH_API_KEY=
HUNTER_API_KEY=
APOLLO_API_KEY=

# Brain One manual opportunity intelligence
# Server-side only. Never expose this in frontend code.
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-8b-instruct
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_TIMEOUT_MS=180000

# Brain Zero public evidence collection
BRAIN_ZERO_TOTAL_TIMEOUT_MS=120000
BRAIN_ZERO_PAGE_TIMEOUT_MS=10000
BRAIN_ZERO_CRAWL_TIMEOUT_MS=45000
BRAIN_ZERO_TECHNICAL_TIMEOUT_MS=20000
BRAIN_ZERO_MAX_PAGES=10
BRAIN_ZERO_MAX_CONCURRENT_REQUESTS=2
BRAIN_ZERO_CACHE_TTL_MS=86400000

SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_TIMEOUT_MS=15000

SENDGRID_API_KEY=
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
CALENDLY_API_KEY=
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
SLACK_WEBHOOK_URL=
HUBSPOT_ACCESS_TOKEN=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
