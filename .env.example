# Server
PORT=8787
# Leave HOST blank locally. Render will bind automatically through the app code.
HOST=

# Email sending
# Recommended on Render: use Resend API over HTTPS.
EMAIL_PROVIDER=auto
RESEND_API_KEY=
BREVO_API_KEY=

# SMTP fallback only. Leave blank if using Resend or Brevo.
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME=CallCatch
SMTP_REPLY_TO=
SMTP_TIMEOUT_MS=15000

# Optional provider/integration placeholders
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_TIMEOUT_MS=15000

SENDGRID_API_KEY=
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
CALENDLY_API_KEY=
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
SLACK_WEBHOOK_URL=
HUBSPOT_ACCESS_TOKEN=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
