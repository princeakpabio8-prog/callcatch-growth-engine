# Railway/runtime
# In production, DATABASE_URL is required. The app will not fall back to local JSON storage.
NODE_ENV=production
HOST=0.0.0.0
PORT=
DATABASE_URL=

# Brave Search
BRAVE_SEARCH_API_KEY=

# NVIDIA / Brain One
# Server-side only. Never expose NVIDIA_API_KEY in frontend code.
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-8b-instruct
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_TIMEOUT_MS=180000
BRAIN_ONE_MAX_DURATION_MS=300000

# Gmail SMTP
# SMTP_PASS must be a Google App Password, not your normal Gmail password.
# Configure secrets through Railway environment variables. Do not commit credentials.
# Gmail SMTP is intended for low-volume, human-approved outreach.
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME=Prince Akpabio | CallCatch
SMTP_REPLY_TO=
SMTP_TIMEOUT_MS=15000

# Brain Zero public evidence collection
BRAIN_ZERO_TOTAL_TIMEOUT_MS=120000
BRAIN_ZERO_PAGE_TIMEOUT_MS=10000
BRAIN_ZERO_CRAWL_TIMEOUT_MS=45000
BRAIN_ZERO_TECHNICAL_TIMEOUT_MS=20000
BRAIN_ZERO_MAX_PAGES=10
BRAIN_ZERO_MAX_CONCURRENT_REQUESTS=2
BRAIN_ZERO_CACHE_TTL_MS=86400000
BRAIN_ZERO_MAX_ACTIVE_RUNS=1
BRAIN_ZERO_MAX_RESPONSE_BYTES=1000000
BRAIN_ZERO_MAX_REDIRECTS=3

# Optional lead enrichment providers
SERPER_API_KEY=
HUNTER_API_KEY=
APOLLO_API_KEY=

# Optional email providers
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
BREVO_API_KEY=
SENDGRID_API_KEY=
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# Optional SMS provider
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_TIMEOUT_MS=15000

# Optional future integrations
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
CALENDLY_API_KEY=
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
SLACK_WEBHOOK_URL=
HUBSPOT_ACCESS_TOKEN=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
